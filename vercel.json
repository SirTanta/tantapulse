{
  "buildCommand": "echo 'no build' && exit 0",
  "outputDirectory": "public",
  "framework": null,
  "crons": [
    {
      "path": "/api/lead-feed/process",
      "schedule": "10 9 * * *"
    },
    {
      "path": "/api/lead-feed/send",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/sales-discovery/process",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/finance/stripe-overnight",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/sample", "destination": "/index.html" },
    { "source": "/unsubscribe", "destination": "/unsubscribe.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/pricing.html", "destination": "/pricing.html" }
  ]
}
